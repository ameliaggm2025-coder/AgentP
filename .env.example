# ============================================================
# Line 官方通知管理後台 — 環境變數範本
# 複製這個檔為 .env.local 並填入實際值（.env.local 不會進 git）
# ============================================================

# --- Supabase ---
# 從 Supabase Dashboard → Project Settings → API 取得
NEXT_PUBLIC_SUPABASE_URL=https://papunpywpamrkyrgjlor.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Line Messaging API ---
# 從 Line Developers Console → 你的 Channel → Messaging API 取得
LINE_CHANNEL_ID=2010756511
LINE_CHANNEL_SECRET=your-channel-secret-here
LINE_CHANNEL_ACCESS_TOKEN=your-long-lived-access-token-here

# --- 後台登入保護 ---
# 自訂一組後台管理密碼（部署前務必改成強密碼）
ADMIN_PASSWORD=change-me-to-a-strong-password
# 用來簽 cookie 的隨機字串（可用 openssl rand -hex 32 產生）
AUTH_SECRET=change-me-random-string

# --- 交易通知 API 金鑰 ---
# 給外部訂單系統呼叫 /api/notify 用（可用 openssl rand -hex 24 產生）
NOTIFY_API_KEY=change-me-random-key

# --- OpenAI（智能客服 AI 回覆用）---
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
